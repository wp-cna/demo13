# Public build-time value for the Community Posting form endpoint.
POSTING_API_URL=

# --- Cloudflare Worker secrets (set with `wrangler secret put`) -------------
# AI vetting of Community Posting submissions (WPCNA owner's Anthropic key).
ANTHROPIC_API_KEY=

# Rule-based review email delivery.
RESEND_API_KEY=
POSTING_EMAIL_FROM=
POSTING_RECIPIENT_EMAILS=

# Optional webhook fallback. Some browser-oriented form services block
# server-side Worker requests.
POSTING_EMAIL_WEBHOOK_URL=
POSTING_CC_EMAILS=

# --- Optional Worker vars ---------------------------------------------------
# Override the posting-vetting model (default claude-sonnet-4-6).
# POSTING_REVIEW_MODEL=claude-haiku-4-5-20251001
