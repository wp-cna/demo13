# Public build-time value for the Community Posting form endpoint.
POSTING_API_URL=

# Cloudflare Worker secrets for rule-based review email delivery.
# Set these with `wrangler secret put`; do not expose them in public HTML.
RESEND_API_KEY=
POSTING_EMAIL_FROM=
POSTING_RECIPIENT_EMAILS=

# Optional webhook fallback. Some browser-oriented form services block server-side Worker requests.
POSTING_EMAIL_WEBHOOK_URL=
POSTING_CC_EMAILS=
