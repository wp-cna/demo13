---
pagination:
  data: neighborhoodStore.all
  size: 1
  alias: neighborhood
permalink: "neighborhoods/{{ neighborhood.slug }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ neighborhood.name }}"
  metaDescription: "{{ neighborhood.displayMetaDescription }}"
  ogImage: "{{ neighborhood.displayHero and neighborhood.displayHero.imagePath or site.defaultOgImage }}"
---
<section class="neighborhood-detail-hero{% if neighborhood.profilePlaceholder %} neighborhood-detail-hero-placeholder{% endif %}">
  {% if neighborhood.profilePlaceholder %}
    <div class="neighborhood-detail-hero-media neighborhood-detail-hero-placeholder-media" aria-label="{{ neighborhood.guideImageLabel }}">
      <span>{{ neighborhood.guideImageLabel }}</span>
    </div>
  {% elif neighborhood.displayHero %}
    <img class="neighborhood-detail-hero-media" src="{{ neighborhood.displayHero.imagePath | withPrefix }}" alt="{{ neighborhood.displayHero.altText }}" loading="eager">
  {% endif %}

  <h1 class="image-hero-label">{{ neighborhood.name }}</h1>
</section>

{% if not neighborhood.profilePlaceholder and neighborhood.displayHero %}
  {% set heroAttributionUrl = neighborhood.displayHero.attributionUrl or '' %}
  {% set heroAttributionExternal = heroAttributionUrl.startsWith('http') %}
  <div class="neighborhood-hero-creditbar">
    <span>{{ neighborhood.displayHero.attributionText }}</span>
    <a href="{{ heroAttributionUrl if heroAttributionExternal else (heroAttributionUrl | withPrefix) }}"{% if heroAttributionExternal %} rel="external noopener"{% endif %}>Source</a>
    <span>{{ neighborhood.displayHero.license }}</span>
  </div>
{% endif %}

<section class="section neighborhood-profile-section">
  <div class="wrap">
    <article class="neighborhood-profile-copy">
      {% if neighborhood.profilePlaceholder %}
        <p>{{ neighborhood.displayDetailParagraphs[0] }}</p>
      {% else %}
        <p>{{ neighborhood.description }}</p>
      {% endif %}

      {% if neighborhood.association %}
        <div class="association-block">
          <h2><span>{{ neighborhood.association.name }}</span></h2>
          <ul>
            {% for officer in neighborhood.association.officers %}
              <li>
                <strong>{{ officer.name }}</strong>, {{ officer.role }}
                {% if officer.phone %}
                  <a href="tel:{{ officer.phone | replace('-', '') }}">{{ officer.phone }}</a>
                {% endif %}
                {% if officer.email %}
                  <a href="mailto:{{ officer.email }}">{{ officer.email }}</a>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
          {% if neighborhood.association.url %}
            <p class="association-website"><a href="{{ neighborhood.association.url }}" rel="external noopener">Visit the association website</a></p>
          {% endif %}
        </div>
      {% endif %}
    </article>
  </div>
</section>
