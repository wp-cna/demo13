---
layout: layouts/base.njk
title: White Plains Council of Neighborhood Associations
metaDescription: The neighborhood-centered civic hub for agendas, events, represented neighborhoods, and useful White Plains information.
---
{% from "components/macros.njk" import eventCard, resourceCard %}

<section class="image-hero image-hero-home">
  <img src="{{ site.heroImage | withPrefix }}" alt="{{ site.heroImageAlt }}" loading="eager">
  <h1 class="image-hero-label" aria-label="The Forum for the Neighborhood Associations of White Plains to Share Ideas and Exchange Information">
    <span class="home-label-desktop-lines" aria-hidden="true">
      <span>The Forum for the Neighborhood</span>
      <span>Associations of White Plains to Share</span>
      <span>Ideas &amp; Exchange Information</span>
    </span>
    <span class="home-label-mobile-copy">
      <span>The Forum for the Neighborhood Associations of</span>
      <span>White Plains to Share Ideas &amp; Exchange Information</span>
    </span>
  </h1>
</section>

<section class="section section-alt represented-neighborhoods-section" id="neighborhoods" data-neighborhood-map>
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Neighborhoods</p>
        <h2>Neighborhood Associations</h2>
        <p>Explore the neighborhood associations currently represented in WPCNA. Use the map for citywide context, then open an association profile to learn more.</p>
      </div>
      <a class="link-arrow" href="{{ '/neighborhoods/' | withPrefix }}">Full Neighborhood Guide</a>
    </div>

    <div class="represented-neighborhoods-layout">
      <div class="interactive-map-panel represented-map-panel">
        <div class="interactive-map-frame represented-map-frame">
          <img
            src="{{ representedNeighborhoods.imagePath | withPrefix }}?v={{ representedNeighborhoods.imageVersion }}"
            alt="{{ representedNeighborhoods.imageAlt }}"
            width="{{ representedNeighborhoods.imageWidth }}"
            height="{{ representedNeighborhoods.imageHeight }}"
            loading="eager"
          >
          <svg
            class="interactive-map-svg represented-map-svg"
            viewBox="0 0 {{ representedNeighborhoods.viewBoxWidth }} {{ representedNeighborhoods.viewBoxHeight }}"
            aria-label="Interactive map of the WPCNA neighborhoods represented on the homepage"
            role="img"
            focusable="false"
            preserveAspectRatio="xMidYMid meet"
          >
            {% for neighborhood in representedNeighborhoods.mappedItems %}
              <path
                class="represented-map-region"
                d="{{ neighborhood.mapRegion.pathD }}"
                data-map-region="{{ neighborhood.slug }}"
                data-neighborhood-trigger
                data-neighborhood-target="{{ neighborhood.slug }}"
                aria-controls="represented-neighborhood-modal"
                aria-haspopup="dialog"
                role="button"
                tabindex="0"
                aria-label="Open {{ neighborhood.name }} neighborhood profile"
              ></path>
            {% endfor %}
          </svg>
        </div>
        <p class="represented-map-caption">Hover or focus a highlighted area on the map or in the list, then select it to open its profile.</p>
      </div>

      <div>
        <div class="represented-neighborhoods-intro">
          <h3>Association Profiles</h3>
        </div>

        <div class="represented-neighborhood-grid">
          {% for neighborhood in representedNeighborhoods.items %}
            <a
              class="represented-neighborhood-card"
              href="{{ neighborhood.detailUrl | withPrefix }}"
              data-map-tile="{{ neighborhood.slug }}"
              aria-label="Open {{ neighborhood.name }} neighborhood profile"
            >
              {% if neighborhood.profilePlaceholder %}
                <span class="represented-neighborhood-card-thumb represented-placeholder-thumb" aria-label="{{ neighborhood.guideImageLabel }}">
                  <span>{{ neighborhood.guideImageLabel }}</span>
                </span>
              {% else %}
                <span class="represented-neighborhood-card-thumb">
                  <img src="{{ (neighborhood.hero.cardImagePath or neighborhood.hero.imagePath) | withPrefix }}" alt="{{ neighborhood.hero.cardAltText or neighborhood.hero.altText }}" loading="lazy">
                </span>
              {% endif %}
              <span>
                <strong>{{ neighborhood.name }}</strong>
                <span class="represented-neighborhood-card-link">View profile</span>
              </span>
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="represented-modal-backdrop" id="represented-neighborhood-modal" data-neighborhood-modal hidden aria-hidden="true" inert>
  <div class="represented-modal-shell" role="dialog" aria-modal="true" tabindex="-1" data-neighborhood-dialog>
    <button class="represented-modal-close" type="button" data-neighborhood-close aria-label="Close neighborhood profile">Close</button>

    {% for neighborhood in representedNeighborhoods.items %}
      <article class="represented-modal-panel" data-neighborhood-panel="{{ neighborhood.slug }}" aria-hidden="true" hidden>
        <div class="represented-modal-layout{% if neighborhood.hero or neighborhood.profilePlaceholder %} represented-modal-layout-media{% endif %}">
          {% if neighborhood.profilePlaceholder %}
            <figure class="represented-modal-figure represented-modal-placeholder" aria-label="{{ neighborhood.guideImageLabel }}">
              <span>{{ neighborhood.guideImageLabel }}</span>
            </figure>
          {% elif neighborhood.hero %}
            <figure class="represented-modal-figure">
              <img src="{{ neighborhood.hero.imagePath | withPrefix }}" alt="{{ neighborhood.hero.altText }}" loading="lazy">
            </figure>
          {% endif %}

          <div class="represented-modal-copy">
            <p class="eyebrow">{{ neighborhood.group }}</p>
            <h2 id="represented-modal-title-{{ neighborhood.slug }}">{{ neighborhood.name }}</h2>
            <p class="represented-modal-teaser">{{ neighborhood.teaser }}</p>
            {% if neighborhood.reviewNote %}
              <p class="represented-modal-note">{{ neighborhood.reviewNote }}</p>
            {% endif %}
            {% for paragraph in neighborhood.bodyParagraphs %}
              <p>{{ paragraph }}</p>
            {% endfor %}

            {% if neighborhood.association %}
              <div class="association-block association-block-compact">
                <h3><span>{{ neighborhood.association.name }}</span></h3>
                <ul>
                  {% for officer in neighborhood.association.officers %}
                    <li>
                      <strong>{{ officer.name }}</strong>, {{ officer.role }}
                      {% if officer.phone %}
                        <a href="tel:{{ officer.phone | replace('-', '') }}">{{ officer.phone }}</a>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
                {% if neighborhood.association.url %}
                  <p class="association-website"><a href="{{ neighborhood.association.url }}" rel="external noopener">Association website</a></p>
                {% endif %}
              </div>
            {% endif %}

            {% if neighborhood.resourceLinks and neighborhood.resourceLinks.length %}
              <div class="represented-modal-links">
                {% for link in neighborhood.resourceLinks %}
                  <a class="link-arrow" href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</div>

<section class="section section-rule" data-upcoming-events data-upcoming-limit="{{ eventStore.homeUpcomingLimit }}">
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Coming Up</p>
        <h2>Upcoming events</h2>
        <p>A curated selection of public meetings, arts events, downtown happenings, and neighborhood programs.</p>
      </div>
      <a class="link-arrow" href="{{ '/events/' | withPrefix }}">See all events</a>
    </div>

    {% if eventStore.homeUpcoming.length %}
      <div class="card-grid">
        {% for event in eventStore.homeUpcoming %}
          {{ eventCard(event, true, loop.index > eventStore.homeUpcomingLimit) }}
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">
        <h3>No upcoming events right now.</h3>
        <p>Check back soon or browse past events.</p>
        <a class="btn btn-primary" href="{{ '/events/' | withPrefix }}">Browse events</a>
      </div>
    {% endif %}
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="section-header">
      <div>
        <p class="eyebrow">Quick Links</p>
        <h2>Useful pages</h2>
        <p>Helpful pages for following meetings, sharing updates, and getting oriented around White Plains.</p>
      </div>
    </div>
    <div class="card-grid card-grid-2">
      {% for resource in resources %}
        {{ resourceCard(resource) }}
      {% endfor %}
    </div>
  </div>
</section>
